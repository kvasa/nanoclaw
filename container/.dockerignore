# Exclude host-side node_modules — they get freshly installed in the image
# by `npm install`. Leaving them in the build context adds ~300 MB per COPY
# layer and can overlay the freshly installed container deps with mismatched
# host-compiled binaries (e.g. the SDK CLI platform dep).
agent-runner/node_modules

# Pre-compiled dist is regenerated by `npm run build` in the image.
agent-runner/dist

# Local dev/CI noise — nothing that belongs in the runtime image.
**/.git
**/.DS_Store
**/*.log
**/npm-debug.log*
**/.env
**/.env.local
