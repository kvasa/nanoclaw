# ── Authentication ────────────────────────────────────────────────────
# Claude Code OAuth token (required — one of CLAUDE_CODE_OAUTH_TOKEN or ANTHROPIC_API_KEY)
CLAUDE_CODE_OAUTH_TOKEN=
# Alternatively, use a direct API key:
# ANTHROPIC_API_KEY=
# Optional: custom Anthropic API base URL
# ANTHROPIC_BASE_URL=

# ── Assistant ─────────────────────────────────────────────────────────
ASSISTANT_NAME="Jarmil"
# Set to true if the assistant has its own WhatsApp number (not shared with user)
# ASSISTANT_HAS_OWN_NUMBER=false
# Timezone (default: system TZ)
# TZ=Europe/Prague

# ── LLM ───────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
# Log detail level: full | summary | none
LLM_LOG_DETAIL=full
LOG_LEVEL=debug

# ── Container ─────────────────────────────────────────────────────────
# CONTAINER_IMAGE=nanoclaw-agent
# CONTAINER_TIMEOUT=300000
# CONTAINER_MAX_OUTPUT_SIZE=100000
# MAX_CONCURRENT_CONTAINERS=3
# IDLE_TIMEOUT=300000
# CREDENTIAL_PROXY_PORT=8384
# CREDENTIAL_PROXY_HOST=host.docker.internal

# ── HTTP API server ───────────────────────────────────────────────────
# Server only starts when API_TOKEN is set.
# API_TOKEN=
# API_PORT=3002
# API_GROUP_ID=assistant
# API_SLACK_CHANNEL_ID=

# ── Slack channel ─────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ONLY=false

# ── Gmail channel ────────────────────────────────────────────────────
# GMAIL_ENABLED=false
# Comma-separated list of allowed sender emails
# GMAIL_ALLOWED_SENDERS=
# Comma-separated list of allowed sender domains
# GMAIL_ALLOWED_DOMAINS=
# Rate limits
# GMAIL_RATE_LIMIT_PER_SENDER=10
# GMAIL_RATE_LIMIT_GLOBAL=50
# GMAIL_RATE_LIMIT_OUTGOING=20
# GMAIL_RATE_LIMIT_READ_EMAILS=100
# GMAIL_RATE_LIMIT_WINDOW_MS=3600000

# ── Apple Calendar (CalDAV) ──────────────────────────────────────────
# APPLE_ID=
# APPLE_APP_PASSWORD=
# CALDAV_BASE_URL=https://caldav.icloud.com

# ── Garmin Connect ───────────────────────────────────────────────────
# GARMIN_EMAIL=
# GARMIN_PASSWORD=

# ── Rohlik MCP ───────────────────────────────────────────────────────
# RHL_EMAIL=
# RHL_PASS=

# ── Voice server (jarmil.eu) ─────────────────────────────────────────
# VOICE_PORT=3003
# VOICE_SECRET=<random-string>       # HMAC secret for JWT tokens
# VOICE_TTS_VOICE=ash
# VOICE_GROUP=main
# Google OAuth2 (create at console.cloud.google.com → APIs & Services → Credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://jarmil.eu/api/voice/auth/callback
# VOICE_ALLOWED_EMAILS=j.kv@snicka.cz

# ── Backup ───────────────────────────────────────────────────────────
# BACKUP_PASSWORD=your-secure-password-here
