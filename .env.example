CLAUDE_CODE_OAUTH_TOKEN=secret
SLACK_BOT_TOKEN=xoxb-secret
SLACK_APP_TOKEN=xapp-secret
SLACK_ONLY=true

ASSISTANT_NAME="Jarmil"
CLAUDE_MODEL=claude-opus-4-6
LLM_LOG_DETAIL=full
LOG_LEVEL=debug

# HTTP API server for direct client access (e.g. pi-assistant)
# Server only starts when API_TOKEN is set.
API_TOKEN=
API_PORT=3002
API_GROUP_ID=assistant

# Backup encryption password (required for backup/restore)
BACKUP_PASSWORD=your-secure-password-here